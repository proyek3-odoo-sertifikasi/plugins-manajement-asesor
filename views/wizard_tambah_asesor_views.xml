<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== -->
    <!-- Wizard Action         -->
    <!-- ===================== -->
    <record id="lsp_penugasan_action_wizard_tambah_asesor" model="ir.actions.act_window">
        <field name="name">Tambah Asesor</field>
        <field name="res_model">lsp.wizard.tambah.asesor</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_penugasan_id': active_id}</field>
    </record>

    <!-- ===================== -->
    <!-- Wizard Form View      -->
    <!-- ===================== -->
    <record id="lsp_penugasan_wizard_tambah_asesor_form" model="ir.ui.view">
        <field name="name">lsp.wizard.tambah.asesor.form</field>
        <field name="model">lsp.wizard.tambah.asesor</field>
        <field name="arch" type="xml">
            <form string="Tambah Asesor ke Penugasan">
                <group>
                    <field name="penugasan_id" readonly="1"/>
                    <field name="preview_info" readonly="1" widget="text"/>
                          <field name="asesor_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_tambah_asesor"
                            string="Tambah Asesor"
                            type="object"
                            class="btn-primary"/>
                    <button string="Batal" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
