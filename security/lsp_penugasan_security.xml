<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== -->
    <!-- Category              -->
    <!-- ===================== -->
    <record model="ir.module.category" id="module_category_lsp">
        <field name="name">LSP</field>
        <field name="description">Hak Akses untuk modul-modul LSP</field>
        <field name="sequence">10</field>
    </record>

    <!-- ===================== -->
    <!-- Privileges (Odoo 19+) -->
    <!-- ===================== -->
    <record id="privilege_lsp_asesor" model="res.groups.privilege">
        <field name="name">Asesor LSP</field>
        <field name="category_id" ref="module_category_lsp"/>
    </record>

    <record id="privilege_lsp_admin" model="res.groups.privilege">
        <field name="name">Admin LSP</field>
        <field name="category_id" ref="module_category_lsp"/>
    </record>

    <!-- ===================== -->
    <!-- Groups                -->
    <!-- ===================== -->

    <!-- Group: Asesor LSP -->
    <record id="group_asesor" model="res.groups">
        <field name="name">Asesor LSP</field>
        <field name="privilege_id" ref="privilege_lsp_asesor"/>
        <field name="comment">Asesor hanya dapat melihat penugasan yang ditugaskan kepadanya (read-only).</field>
    </record>

    <!-- Group: Admin LSP -->
    <record id="group_admin_lsp" model="res.groups">
        <field name="name">Admin LSP</field>
        <field name="privilege_id" ref="privilege_lsp_admin"/>
        <field name="implied_ids" eval="[(4, ref('group_asesor'))]"/>
        <field name="comment">Admin LSP dapat membuat, mengedit, mengunci, dan membuka kunci penugasan.</field>
    </record>

    <!-- ===================== -->
    <!-- Record Rules          -->
    <!-- ===================== -->

    <!-- Rule 1: Asesor hanya lihat line penugasan miliknya -->
    <record id="lsp_penugasan_line_asesor_rule" model="ir.rule">
        <field name="name">Asesor: Hanya Lihat Line Miliknya</field>
        <field name="model_id" ref="model_lsp_penugasan_line"/>
        <field name="domain_force">[('asesor_id.id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_asesor'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Rule 2: Asesor hanya lihat penugasan yang mengandung dirinya -->
    <record id="lsp_penugasan_asesor_asesor_rule" model="ir.rule">
        <field name="name">Asesor: Hanya Lihat Penugasan Miliknya</field>
        <field name="model_id" ref="model_lsp_penugasan_asesor"/>
        <field name="domain_force">[('penugasan_line_ids.asesor_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_asesor'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Rule 3: Admin LSP - full access ke penugasan -->
    <record id="lsp_penugasan_asesor_admin_rule" model="ir.rule">
        <field name="name">Admin LSP: Full Access Penugasan</field>
        <field name="model_id" ref="model_lsp_penugasan_asesor"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_admin_lsp'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Rule 4: Admin LSP - full access ke penugasan line -->
    <record id="lsp_penugasan_line_admin_rule" model="ir.rule">
        <field name="name">Admin LSP: Full Access Penugasan Line</field>
        <field name="model_id" ref="model_lsp_penugasan_line"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_admin_lsp'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
